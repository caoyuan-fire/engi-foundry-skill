      "localPath": "skills/engifoundry/modules/superpowers-compatible-discipline.md",
      "required": false
    }
  },
  "remoteSource": {
    "type": "github",
    "repo": "caoyuan-fire/engi-foundry-skill",
    "defaultRef": "main"
  }
}
